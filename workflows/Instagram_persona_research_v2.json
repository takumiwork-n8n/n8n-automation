        {
            "parameters": {
                "jsCode": "// Run Once for All Items モードで使用\n// このノードは「Perplexityリサーチ結果」の後に配置すること\n\nconst items = $input.all(); // Perplexityのリサーチ結果（1アイテム=1トピック）\n\n// Geminiノードからペルソナと元のトピックを取得\nconst geminiOutput = $node[\"Gemini: ペルソナ＋ネタ生成\"].json.output;\nconst rawPersona = geminiOutput.persona;\n\n// persona を Supabase 型（文字列フラット）に変換\nconst persona = {\n  age_range: rawPersona.age_range.value,\n  occupation: rawPersona.occupation.value,\n  pain_points: rawPersona.pain_points.map(p => p.value),\n  desires: rawPersona.desires.map(d => d.value),\n  behavior_pattern: rawPersona.behavior_pattern.value\n};\n\n// Perplexityのリサーチ結果を ResearchedTopic 形式に変換\nconst topics = items.map(item => {\n  const d = item.json;\n\n  const statsSummary = (d.stats || [])\n    .map(s => `・${s.fact}`)\n    .join('\\n');\n\n  const trendsSummary = (d.trends || [])\n    .map(t => `・${t.title}`)\n    .join('\\n');\n\n  const research_summary = [statsSummary, trendsSummary]\n    .filter(s => s.length > 0)\n    .join('\\n');\n\n  // Geminiが生成したtopicsからreason/target_metricを引き当て\n  const geminiTopic = (geminiOutput.topics || [])\n    .find(t => t.topic === d.topic) || {};\n\n  return {\n    topic: d.topic,\n    reason: geminiTopic.reason || d.competitor_patterns?.[0]?.applicable_tip || '',\n    research_summary,\n    sources: d.citations || []\n  };\n});\n\nreturn [{\n  json: {\n    user_id: \"5659d84b-24d9-4978-ad06-90e6c046b413\", // 認証ノードから取得する場合は差し替え\n    persona,\n    topics,\n    post_count: $node[\"Gemini: ペルソナ＋ネタ生成\"].json.output.analysis_summary?.top_reach_posts?.length || 0,\n    analyzed_at: new Date().toISOString()\n  }\n}];"
            },
