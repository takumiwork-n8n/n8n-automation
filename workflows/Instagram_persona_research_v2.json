                "options": {}
            },
            "name": "Google Gemini Chat Model",
            "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
            "typeVersion": 1,
            "position": [
                2208,
                1504
            ],
            "id": "c8ffdc71-3a31-4b25-90f9-cc80ec82859d",
            "credentials": {
                "googlePalmApi": {
                    "id": "aYlcpx81lbjQfwmb",
                    "name": "Google Gemini(PaLM) Api account"
                }
            }
        },
        {
            "parameters": {
                "jsonSchemaExample": "{\n  \"analysis_summary\": {\n    \"top_reach_posts\": [\"post_idを最大3つ\"],\n    \"top_saved_posts\": [\"post_idを最大3つ\"],\n    \"common_pattern\": \"上位投稿に共通するトピック・表現の特徴\"\n  },\n  \"persona\": {\n    \"age_range\": {\"value\": \"推定値\", \"confidence\": \"high/medium/low\"},\n    \"occupation\": {\"value\": \"推定値\", \"confidence\": \"high/medium/low\"},\n    \"pain_points\": [\n      {\"value\": \"課題\", \"evidence\": \"どのデータからの推定か\"}\n    ],\n    \"desires\": [\n      {\"value\": \"願望\", \"evidence\": \"どのデータからの推定か\"}\n    ],\n    \"behavior_pattern\": {\"value\": \"行動傾向\", \"confidence\": \"high/medium/low\"}\n  },\n  \"topics\": [\n    {\n      \"topic\": \"投稿タイトル案\",\n      \"reason\": \"データ根拠を具体的に記述\",\n      \"target_metric\": \"この投稿で改善を狙う指標（reach/saved/follows）\"\n    }\n  ]\n}"
            },
            "name": "Structured Output Parser",
            "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
            "typeVersion": 1.3,
            "position": [
                2352,
                1504
