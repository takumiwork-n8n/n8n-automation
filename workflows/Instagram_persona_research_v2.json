        {
            "parameters": {
                "jsCode": "const raw = $input.first().json;\nconst currentItem = $('Loop Over Items').first().json; // 現在のバッチアイテム\n\nconst text = raw.message ?? raw.choices?.[0]?.message?.content ?? JSON.stringify(raw);\nconst jsonMatch = text.match(/```json\\s*([\\s\\S]*?)```/) || text.match(/(\\{[\\s\\S]*\\})/);\n\nlet parsed;\ntry {\n  parsed = JSON.parse(jsonMatch ? jsonMatch[1].trim() : text);\n} catch (e) {\n  return [{\n    json: {\n      parse_error: true,\n      raw_text: text,\n      topic: currentItem.topic ?? 'unknown',\n      reason: currentItem.reason ?? '',\n      target_metric: currentItem.target_metric ?? ''\n    }\n  }];\n}\n\nparsed.citations = raw.citations ?? [];\n// 元のトピック情報をマージ\nparsed._original = {\n  topic: currentItem.topic ?? '',\n  reason: currentItem.reason ?? '',\n  target_metric: currentItem.target_metric ?? ''\n};\n\nreturn [{ json: parsed }];"
            },
