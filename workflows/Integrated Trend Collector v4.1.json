        {
            "parameters": {
                "jsCode": "// ショート動画 & 低パフォーマンス動画を除外\nreturn $input.all().filter(item => {\n  const stats = item.json.statistics || {};\n  const snippet = item.json.snippet || {};\n  const contentDetails = item.json.contentDetails || {};\n\n  // 1. タイトル・説明に #shorts が含まれる場合は除外\n  const title = (snippet.title || '').toLowerCase();\n  const description = (snippet.description || '').toLowerCase();\n  if (title.includes('#shorts') || description.includes('#shorts')) {\n    return false;\n  }\n\n  // 2. 動画時間が180秒（3分）未満はショート扱いで除外\n  if (contentDetails.duration) {\n    const match = contentDetails.duration.match(/PT(?:(\\d+)H)?(?:(\\d+)M)?(?:(\\d+)S)?/);\n    if (match) {\n      const hours = parseInt(match[1] || 0);\n      const minutes = parseInt(match[2] || 0);\n      const seconds = parseInt(match[3] || 0);\n      const totalSeconds = hours * 3600 + minutes * 60 + seconds;\n      if (totalSeconds < 180) return false;\n    }\n  }\n\n  // 3. 再生数が1000未満は低パフォーマンスとして除外\n  const viewCount = parseInt(stats.viewCount || 0);\n  if (viewCount < 1000) return false;\n\n  return true;\n});"
            },
