        {
            "parameters": {
                "jsCode": "const raw = $input.first().json;\nconst rawText = raw.content.parts[0].text;\n\n// ===== パース =====\nfunction extractSection(text, heading) {\n  const regex = new RegExp(`\\\\*\\\\*${heading}[：:]?\\\\*\\\\*[\\\\s\\\\S]*?(?=\\\\n\\\\*\\\\*|$)`);\n  const match = text.match(regex);\n  if (!match) return \"\";\n  return match[0].replace(new RegExp(`\\\\*\\\\*${heading}[：:]?\\\\*\\\\*`), \"\").trim();\n}\nfunction extractBullets(text, heading) {\n  return extractSection(text, heading)\n    .split('\\n')\n    .filter(l => l.trim().startsWith('*') || l.trim().startsWith('-'))\n    .map(l => l.replace(/^\\s*[\\*\\-]\\s*/, \"\").trim())\n    .filter(l => l.length > 0);\n}\nfunction extractNumbered(text, heading) {\n  return extractSection(text, heading)\n    .split('\\n')\n    .filter(l => /^\\s*\\d+\\./.test(l))\n    .map(l => l.replace(/^\\s*\\d+\\.\\s*/, \"\").trim())\n    .filter(l => l.length > 0);\n}\n\nconst title = $('Edit Fields').first().json.video_title || \"（タイトル不明）\";\nconst channelName = $('Edit Fields').first().json.channel_name || \"\";\nconst viewCount = $('Edit Fields').first().json.viewCount || 0;\nconst likeCount = $('Edit Fields').first().json.likeCount || 0;\nconst videoURL = $('Edit Fields').first().json.videoURL || \"\";\n\nconst summaryMatch = rawText.match(/\\*\\*動画概要[：:]?\\*\\*\\s*([\\s\\S]*?)(?=\\n\\*\\*|$)/);\nconst summary = summaryMatch ? summaryMatch[1].trim() : \"\";\nconst techMatch = rawText.match(/\\*\\*使用技術[：:]?\\*\\*\\s*([^\\n]+)/);\nconst techRaw = techMatch ? techMatch[1].trim() : \"なし\";\nconst technologies = (techRaw === \"なし\" || techRaw === \"\") ? [] : techRaw.split(',').map(t => ({ name: t.trim() })).filter(t => t.name.length > 0);\nconst conclusionMatch = rawText.match(/\\*\\*結論[：:]?\\*\\*\\s*([\\s\\S]*?)(?=\\n\\*\\*|$)/);\nconst conclusion = conclusionMatch ? conclusionMatch[1].trim() : \"\";\nconst reasons = extractBullets(rawText, \"理由\");\nconst examples = extractBullets(rawText, \"具体例\");\nconst learnings = extractNumbered(rawText, \"この動画から得られる学び\");\n\n// ===== ブロックヘルパー =====\nconst divider = { object: \"block\", type: \"divider\", divider: {} };\n\nfunction callout(emoji, content, color) {\n  return {\n    object: \"block\", type: \"callout\",\n    callout: {\n      rich_text: [{ type: \"text\", text: { content } }],\n      icon: { type: \"emoji\", emoji },\n      color: color || \"default\"\n    }\n  };\n}\nfunction h2(content, color) {\n  return {\n    object: \"block\", type: \"heading_2\",\n    heading_2: {\n      rich_text: [{ type: \"text\", text: { content }, annotations: { bold: true } }],\n      color: color || \"default\"\n    }\n  };\n}\nfunction h3(content) {\n  return {\n    object: \"block\", type: \"heading_3\",\n    heading_3: { rich_text: [{ type: \"text\", text: { content } }] }\n  };\n}\nfunction quote(content) {\n  return {\n    object: \"block\", type: \"quote\",\n    quote: {\n      rich_text: [{ type: \"text\", text: { content }, annotations: { bold: true } }],\n      color: \"default\"\n    }\n  };\n}\nfunction bullet(content) {\n  const m = content.match(/^\\*\\*(.+?)\\*\\*[：:]\\s*(.*)/);\n  if (m) return {\n    object: \"block\", type: \"bulleted_list_item\",\n    bulleted_list_item: { rich_text: [\n      { type: \"text\", text: { content: m[1] + \": \" }, annotations: { bold: true } },\n      { type: \"text\", text: { content: m[2] } }\n    ]}\n  };\n  return {\n    object: \"block\", type: \"bulleted_list_item\",\n    bulleted_list_item: { rich_text: [{ type: \"text\", text: { content } }] }\n  };\n}\nfunction numbered(content, idx) {\n  return {\n    object: \"block\", type: \"numbered_list_item\",\n    numbered_list_item: { rich_text: [{ type: \"text\", text: { content } }] }\n  };\n}\nfunction toggle(emoji, label, children) {\n  return {\n    object: \"block\", type: \"toggle\",\n    toggle: {\n      rich_text: [{ type: \"text\", text: { content: emoji + \"  \" + label }, annotations: { bold: true } }],\n      children\n    }\n  };\n}\nfunction paragraph(content) {\n  return {\n    object: \"block\", type: \"paragraph\",\n    paragraph: { rich_text: [{ type: \"text\", text: { content } }] }\n  };\n}\n\n// ===== ブロック組み立て =====\nconst children = [];\n\n// ── 動画概要 callout ──\nchildren.push(callout(\"📺\", summary, \"blue_background\"));\n\n// ── 統計情報 callout ──\nconst statsText = `👁  再生数: ${Number(viewCount).toLocaleString()}　　👍  いいね数: ${Number(likeCount).toLocaleString()}　　📺  ${channelName}`;\nchildren.push(callout(\"📊\", statsText, \"gray_background\"));\n\nchildren.push(divider);\n\n// ── 結論（quote で強調）──\nchildren.push(h2(\"💡  結論\"));\nchildren.push(quote(conclusion));\n\nchildren.push(divider);\n\n// ── 理由（toggle）──\nif (reasons.length > 0) {\n  children.push(toggle(\"🔍\", \"理由を見る\", reasons.map(r => bullet(r))));\n}\n\n// ── 具体例（toggle）──\nif (examples.length > 0) {\n  children.push(toggle(\"🧪\", \"具体例を見る\", examples.map(e => bullet(e))));\n}\n\nchildren.push(divider);\n\n// ── 学び（numbered callout wrapper）──\nif (learnings.length > 0) {\n  children.push(h2(\"🎯  この動画から得られる学び\"));\n  learnings.forEach(l => children.push(numbered(l)));\n}\n\nchildren.push(divider);\n\n// ── フッター ──\nchildren.push(callout(\"🔗\", `元動画: ${videoURL}`, \"default\"));\n\n// ===== Notion APIボディ =====\nreturn [{\n  json: {\n    parent: { database_id: $('config').first().json.notion_database_id },\n    properties: {\n      \"タイトル\": {\n        title: [{ text: { content: title } }]\n      }\n    },\n    children,\n    _technologies: technologies\n  }\n}];"
            },
