            "parameters": {
                "jsCode": "// シートのデータからvideoIdを抽出\n// URLカラムから抽出する場合\nconst items = $input.all();\nreturn items.map(item => {\n  let videoId = item.json.videoId;\n  \n  // URLからvideoIdを抽出（URLカラムがある場合）\n  if (!videoId && item.json.URL) {\n    const match = item.json.URL.match(/v=([^&]+)/);\n    videoId = match ? match[1] : null;\n  }\n  \n  return {\n    json: {\n      videoId: videoId\n    }\n  };\n}).filter(item => item.json.videoId);"
            },
