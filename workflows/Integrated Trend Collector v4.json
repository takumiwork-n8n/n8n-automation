        {
            "parameters": {
                "jsCode": "const seen = new Set();\nconst unique = [];\n\nfor (const item of $input.all()) {\n  const id = item.json.id?.replace('yt:video:', '');\n  if (id && !seen.has(id)) {\n    seen.add(id);\n    unique.push({\n      json: {\n        videoId: id,\n        title: item.json.title,\n        description: item.json.contentSnippet || '',\n        publishedAt: item.json.isoDate || item.json.pubDate\n      }\n    });\n  }\n}\n\nreturn unique;"
            },
